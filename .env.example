# =============================================================================
# Sphere Guardian AI — environment configuration
# Copy to .env.local. Never commit secrets. Testnet2 oracle key is PUBLIC.
# =============================================================================

# live (default) | mock (offline CI only)
SPHERE_MODE=live
SPHERE_NETWORK=testnet2

# Guardian agent nametag (Sphere Identity on testnet2)
GUARDIAN_NAMETAG=sg-guardian
# Second live wallet that sells diagnostics (real A2A settlement)
GUARDIAN_PEER_NAMETAG=sg-diag-peer
GUARDIAN_ENABLE_PEER=true

# Loop timing
GUARDIAN_TICK_MS=12000
GUARDIAN_NEGOTIATION_MS=8000
GUARDIAN_MAX_BUDGET=5
# UCT is the testnet2 fungible token used by Sphere Wallet
GUARDIAN_CURRENCY=UCT
GUARDIAN_MAX_INCIDENTS=3
GUARDIAN_DATA_DIR=.data

# --- Live Sphere Testnet v2 ---
# Public testnet2 gateway key (NOT a mainnet secret)
SPHERE_ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
SPHERE_WALLET_API_URL=https://wallet-api.unicity.network
SPHERE_DATA_DIR=.data/sphere-wallet
SPHERE_TOKENS_DIR=.data/sphere-tokens
SPHERE_PEER_DATA_DIR=.data/sphere-peer-wallet
SPHERE_PEER_TOKENS_DIR=.data/sphere-peer-tokens
SPHERE_DEVICE_ID=sphere-guardian-ai-device
SPHERE_PEER_DEVICE_ID=sphere-guardian-peer-device

# Optional probe thresholds (ms / %)
# THRESHOLD_API_LATENCY_MS=1500
# THRESHOLD_RESPONSE_MS=2000
# THRESHOLD_UPTIME_MIN=97
# THRESHOLD_FAILURE_PCT=15

# --- Optional PostgreSQL persistence ---
# DATABASE_URL=postgresql://user:pass@localhost:5432/sphere_guardian

# --- Optional AI provider (OpenAI-compatible) ---
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

LOG_LEVEL=info
